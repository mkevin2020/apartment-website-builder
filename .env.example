# Copy this file to .env.local and fill in your actual values
# See ENV_EXAMPLE.md for detailed instructions

# OpenAI Configuration
# Get from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk_live_YOUR_KEY_HERE

# Supabase Configuration
# Get from Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ_YOUR_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=eyJ_YOUR_KEY_HERE

# Ollama Configuration (Optional - for local AI model)
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b

# Google AI Configuration (Optional - fallback if Ollama is not available)
GOOGLE_AI_API_KEY=your_google_ai_key_here
